# deSEC (https://desec.io) DNS-01 provider — ALTERNATIVE to the self-hosted ct-dns.
# The self-hosted ct-dns backend stays available; select one with the variable below.
#
# Where these go depends on the deployment (see docs/dns01-desec.md §4):
#  - self-host Compose: append to docker/deploy/.env  (the file the containers load;
#    a root ./.env is NOT read):  cat config/desec.env.example >> docker/deploy/.env
#  - standalone process: export these in the ACME client's environment.
# NEVER commit the real token.

# Which DNS-01 backend the ACME client uses: "self-hosted" (ct-dns) or "desec".
CT_ACME_DNS_PROVIDER=desec

# deSEC API token (dashboard -> Token Management). Read at startup, never logged.
# Best practice: restrict the token to this domain and the "_acme-challenge*" subname.
DESEC_TOKEN=replace-with-your-desec-token

# The zone hosted at deSEC (delegate its NS to ns1.desec.io / ns2.desec.org,
# or use a free <name>.dedyn.io zone).
DESEC_DOMAIN=bunsenbrenner.org

# Optional: override the API base (default shown). Only change for local testing.
# DESEC_API_BASE=https://desec.io/api/v1

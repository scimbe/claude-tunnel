{
  "realm": "ct-demo",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "verifyEmail": false,
  "resetPasswordAllowed": true,
  "defaultSignatureAlgorithm": "RS256",
  "clients": [
    {
      "clientId": "ct-portal",
      "name": "claude-tunnel customer portal",
      "secret": "${KC_PORTAL_CLIENT_SECRET}",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "https://bunsenbrenner.org/portal/callback",
        "http://localhost:8090/portal/callback"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "access.token.signed.response.alg": "RS256",
        "id.token.signed.response.alg": "RS256",
        "post.logout.redirect.uris": "https://bunsenbrenner.org/portal+http://localhost:8090/portal"
      },
      "protocolMappers": [
        {
          "name": "sub",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "id",
            "claim.name": "sub",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        }
      ],
      "defaultClientScopes": ["email", "profile"]
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "linkOnly": false,
      "config": {
        "clientId": "${KC_GOOGLE_CLIENT_ID:}",
        "clientSecret": "${KC_GOOGLE_CLIENT_SECRET:}",
        "syncMode": "IMPORT"
      }
    },
    {
      "alias": "github",
      "providerId": "github",
      "enabled": true,
      "trustEmail": false,
      "storeToken": false,
      "linkOnly": false,
      "config": {
        "clientId": "${KC_GITHUB_CLIENT_ID:}",
        "clientSecret": "${KC_GITHUB_CLIENT_SECRET:}",
        "syncMode": "IMPORT"
      }
    },
    {
      "alias": "gitlab",
      "providerId": "gitlab",
      "enabled": true,
      "trustEmail": false,
      "storeToken": false,
      "linkOnly": false,
      "config": {
        "clientId": "${KC_GITLAB_CLIENT_ID:}",
        "clientSecret": "${KC_GITLAB_CLIENT_SECRET:}",
        "syncMode": "IMPORT"
      }
    }
  ]
}

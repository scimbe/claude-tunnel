{
  "realm": "ct-demo",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "verifyEmail": false,
  "resetPasswordAllowed": true,
  "defaultSignatureAlgorithm": "RS256",
  "clients": [
    {
      "clientId": "ct-portal",
      "name": "claude-tunnel customer portal",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "https://bunsenbrenner.org/portal/callback",
        "http://localhost:8090/portal/callback"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "access.token.signed.response.alg": "RS256",
        "id.token.signed.response.alg": "RS256",
        "post.logout.redirect.uris": "https://bunsenbrenner.org/portal+http://localhost:8090/portal"
      },
      "defaultClientScopes": ["email", "profile"]
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "linkOnly": false,
      "config": {
        "clientId": "${env.KC_GOOGLE_CLIENT_ID:}",
        "clientSecret": "${env.KC_GOOGLE_CLIENT_SECRET:}",
        "syncMode": "IMPORT"
      }
    },
    {
      "alias": "github",
      "providerId": "github",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "linkOnly": false,
      "config": {
        "clientId": "${env.KC_GITHUB_CLIENT_ID:}",
        "clientSecret": "${env.KC_GITHUB_CLIENT_SECRET:}",
        "syncMode": "IMPORT"
      }
    },
    {
      "alias": "gitlab",
      "providerId": "gitlab",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "linkOnly": false,
      "config": {
        "clientId": "${env.KC_GITLAB_CLIENT_ID:}",
        "clientSecret": "${env.KC_GITLAB_CLIENT_SECRET:}",
        "syncMode": "IMPORT"
      }
    }
  ]
}

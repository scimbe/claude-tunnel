# Self-host configuration + secrets template (M21.1b).
# Copy to docker/deploy/.env and edit. Do NOT commit the real .env.

# Published ports on the host.
CONTROL_PLANE_PORT=8090
EDGE_PORT=4433

# Proof-of-Work difficulty for rendezvous (higher = more abuse-resistant, more
# client cost). Production default is higher than the testbed's 8.
EDGE_POW_DIFFICULTY=16

# OIDC / Keycloak issuer URL (the realm). The control plane verifies bearer
# tokens on the /me/* endpoints against this issuer. Leave empty to disable
# authenticated endpoints during initial bring-up.
CT_OIDC_ISSUER=https://keycloak.example/realms/claude-tunnel

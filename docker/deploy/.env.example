# Self-host configuration + secrets template (M21.1b).
# Copy to docker/deploy/.env and edit. Do NOT commit the real .env.

# Published ports on the host.
CONTROL_PLANE_PORT=8090
EDGE_PORT=4433

# Proof-of-Work difficulty for rendezvous (higher = more abuse-resistant, more
# client cost). Production default is higher than the testbed's 8.
EDGE_POW_DIFFICULTY=16

# OIDC / Keycloak issuer URL (the realm). The control plane verifies bearer
# tokens on the /me/* endpoints against this issuer. Leave empty to disable
# authenticated endpoints during initial bring-up.
CT_OIDC_ISSUER=https://keycloak.example/realms/claude-tunnel

# --- Optional demo subsystems (examples/help-site, examples/flappy-demo) --------
# Only needed if you run the toggleable demo sites through the Browser Plane.

# deSEC API token so the demo's Caddy origin can obtain a Let's Encrypt cert via
# DNS-01 (help-site + flappy-demo). See docs/dns01-desec.md. Leave empty if unused.
DESEC_TOKEN=

# flappy-demo (#168): the first-layer gate password the operator sets out-of-band.
# examples/flappy-demo/run-demo.sh hashes THIS into an untracked gate.json (only the
# SHA-256 is ever stored/served — never the plaintext, never committed). Set it to
# your chosen demo password to bring flappy-demo.<zone> online; leave empty if unused.
FLAPPY_DEMO_PASSWORD=

# Origin for the flappy-demo.bunsenbrenner.org demo — same shape as the
# help.bunsenbrenner.org demo (examples/help-site): Caddy terminates TLS with a
# real Let's Encrypt certificate obtained via DNS-01 against deSEC, so it needs NO
# inbound :80/:443 of its own. The Browser-Plane agent forwards the raw TLS here;
# TLS terminates at this origin, keeping the edge/plane payload-blind.
#
# While testing, uncomment the staging CA to avoid Let's Encrypt rate limits.
{
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
	email admin@bunsenbrenner.org
}

flappy-demo.bunsenbrenner.org {
	root * /srv
	file_server
	encode gzip
	tls {
		# DNS-01 via deSEC (token from the environment; see docs/dns01-desec.md).
		dns desec {
			token {$DESEC_TOKEN}
		}
		resolvers ns1.desec.io ns2.desec.org
		# deSEC enforces a zone minimum_ttl of 3600s and rejects TTL 0 (HTTP 400).
		dns_ttl 3600s
		# Give LE's multi-vantage-point validation time to read the TXT before Caddy
		# deletes it.
		propagation_delay 30s
		propagation_timeout 2m
	}
	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
	}
}
